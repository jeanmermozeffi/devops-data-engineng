    echo ""
    echo -e "${WHITE}SCRIPTS:${NC} ${CYAN}$DEVOPS_ROOT/scripts/${NC}"
    echo ""
}

# ============================================================================
# MAIN
# ============================================================================

main() {
    # Si aucun argument, lancer le mode interactif
    if [ $# -eq 0 ]; then
        cmd_interactive
        exit 0
    fi

    COMMAND=$1
    shift

    case "$COMMAND" in
        init)
            cmd_init
            ;;
        deploy)
            cmd_deploy "$@"
            ;;
        package)
            cmd_package "$@"
            ;;
        registry)
            cmd_registry "$@"
            ;;
        audit)
            cmd_audit "$@"
            ;;
        encrypt)
            cmd_encrypt "$@"
            ;;
        deploy-registry)
            cmd_deploy_registry "$@"
            ;;
        labels)
            cmd_labels "$@"
            ;;
        interactive|menu)
            cmd_interactive
            ;;
        help|--help|-h)
            cmd_help
            ;;
        *)
            log_error "Commande inconnue: $COMMAND"
            echo ""
            cmd_help
            exit 1
            ;;
    esac
}

main "$@"
