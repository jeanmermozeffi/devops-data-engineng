#!/usr/bin/env bash

# ============================================================================
# DevOps CLI - Gestionnaire de déploiement centralisé
# ============================================================================
#
# Ce script permet de déployer n'importe quel projet depuis un endroit unique
# Usage: devops <command> [options]
#
# ============================================================================

set -e

# Couleurs
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
NC='\033[0m'

# Chemins - Résoudre le symlink pour trouver le vrai chemin
SCRIPT_PATH="${BASH_SOURCE[0]}"
# Résoudre les symlinks (compatible macOS et Linux)
while [ -L "$SCRIPT_PATH" ]; do
    SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
    SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
    [[ $SCRIPT_PATH != /* ]] && SCRIPT_PATH="$SCRIPT_DIR/$SCRIPT_PATH"
done
DEVOPS_ROOT="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
CURRENT_PROJECT_DIR="$(pwd)"

# ============================================================================
# FONCTIONS D'AFFICHAGE
# ============================================================================

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[✓]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_header() {
    echo -e "\n${CYAN}========================================${NC}"
    echo -e "${WHITE}$1${NC}"
    echo -e "${CYAN}========================================${NC}\n"
}

# ============================================================================
# CHARGEMENT DE LA CONFIGURATION
# ============================================================================

load_project_config() {
    local config_file="$CURRENT_PROJECT_DIR/.devops.yml"

    if [ ! -f "$config_file" ]; then
        log_error "Fichier .devops.yml introuvable dans $(pwd)"
        log_info "Créez-en un avec: devops init"
        exit 1
    fi

    log_info "Chargement de la configuration: $config_file"

    # Parser "flat" : uniquement les clés top-level "key: value".
    # Les sous-clés YAML imbriquées sont traitées ensuite.
    while IFS= read -r line || [ -n "$line" ]; do
        # Ignorer commentaires, lignes vides et blocs imbriqués
        [[ "$line" =~ ^[[:space:]]*$ ]] && continue
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        [[ "$line" =~ ^[[:space:]] ]] && continue
        [[ "$line" != *:* ]] && continue

        key="${line%%:*}"
        value="${line#*:}"
        key=$(echo "$key" | xargs)

        # Nettoyer la valeur
        value=$(echo "$value" | sed 's/[[:space:]]#.*$//' | xargs | sed -e 's/^"//' -e 's/"$//' -e "s/^'//" -e "s/'$//")

        # Export des variables connues
        case "$key" in
            project_name) export PROJECT_NAME="$value" ;;
            compose_project_name) export COMPOSE_PROJECT_NAME="$value" ;;
            label_namespace) export LABEL_NAMESPACE="$value" ;;
            registry_username) export REGISTRY_USERNAME="$value" ;;
            registry_url) export REGISTRY_URL="$value" ;;
            image_name) export IMAGE_NAME="$value" ;;
            git_repo) export GIT_REPO="$value" ;;
            github_token) export GITHUB_TOKEN="$value" ;;
            dev_branch) export DEV_BRANCH="$value" ;;
            staging_branch) export STAGING_BRANCH="$value" ;;
            prod_branch) export PROD_BRANCH="$value" ;;
            dev_port) export DEV_PORT="$value" ;;
            staging_port) export STAGING_PORT="$value" ;;
            prod_port) export PROD_PORT="$value" ;;
            redis_dev_port) export REDIS_DEV_PORT="$value" ;;
            redis_staging_port) export REDIS_STAGING_PORT="$value" ;;
            redis_prod_port) export REDIS_PROD_PORT="$value" ;;
            postgres_user) export POSTGRES_USER="$value" ;;
            postgres_password) export POSTGRES_PASSWORD="$value" ;;
            postgres_db) export POSTGRES_DB="$value" ;;
            postgres_dev_port) export POSTGRES_DEV_PORT="$value" ;;
            postgres_staging_port) export POSTGRES_STAGING_PORT="$value" ;;
            postgres_prod_port) export POSTGRES_PROD_PORT="$value" ;;
            deployment_dir) export DEPLOYMENT_DIR="$value" ;;
            dockerfile_dir) export DOCKERFILE_DIR="$value" ;;
            # Configuration serveur distant SSH
            server_name) export SERVER_NAME="$value" ;;
            server_host) export SERVER_HOST="$value" ;;
            server_port) export SERVER_PORT="$value" ;;
            server_user) export SERVER_USER="$value" ;;
            server_ssh_key) export SERVER_SSH_KEY="$value" ;;
            server_deploy_path) export SERVER_DEPLOY_PATH="$value" ;;
            # Structure du projet
            app_source_dir) export APP_SOURCE_DIR="$value" ;;
            app_dest_dir) export APP_DEST_DIR="$value" ;;
            requirements_path) export REQUIREMENTS_PATH="$value" ;;
            app_entrypoint) export APP_ENTRYPOINT="$value" ;;
            app_python_path) export APP_PYTHON_PATH="$value" ;;
            workdir) export WORKDIR="$value" ;;
            compose_files|compose_files_registry)
                # Ignore, sera traité séparément
                ;;
            *)
                # Exporter toutes les autres variables (variables personnalisées)
                # Convertir clé en MAJUSCULES avec underscores
                local var_name=$(echo "$key" | tr '[:lower:]' '[:upper:]' | tr '-' '_')
                export "$var_name=$value"
                ;;
        esac
    done < "$config_file"

    # Support format YAML imbriqué (project.name, registry.username, etc.)
    get_nested_yaml_value() {
        local section="$1"
        local nested_key="$2"
        local file="$3"

        awk -v section="$section" -v nested_key="$nested_key" '
            function trim(s) {
                gsub(/^[ \t]+|[ \t]+$/, "", s)
                return s
            }
            BEGIN { in_section=0 }
            $0 ~ "^[[:space:]]*" section ":[[:space:]]*$" { in_section=1; next }
            in_section && $0 ~ "^[^[:space:]]" { in_section=0 }
            in_section && $0 ~ "^[[:space:]]+" nested_key ":[[:space:]]*" {
                line=$0
                sub(/^[[:space:]]*[^:]+:[[:space:]]*/, "", line)
                sub(/[[:space:]]+#.*$/, "", line)
                line=trim(line)
                gsub(/^"|"$/, "", line)
                gsub(/^'\''|'\''$/, "", line)
                print line
                exit
            }
        ' "$file"
    }

    local nested_value=""
    nested_value=$(get_nested_yaml_value "project" "name" "$config_file")
    [ -n "$nested_value" ] && PROJECT_NAME="$nested_value"

    nested_value=$(get_nested_yaml_value "project" "label_namespace" "$config_file")
    [ -n "$nested_value" ] && LABEL_NAMESPACE="$nested_value"

    nested_value=$(get_nested_yaml_value "registry" "url" "$config_file")
    [ -n "$nested_value" ] && REGISTRY_URL="$nested_value"

    nested_value=$(get_nested_yaml_value "registry" "username" "$config_file")
    if [ -z "$nested_value" ]; then
        nested_value=$(get_nested_yaml_value "registry" "registry_username" "$config_file")
    fi
    [ -n "$nested_value" ] && REGISTRY_USERNAME="$nested_value"

    nested_value=$(get_nested_yaml_value "registry" "image_name" "$config_file")
    if [ -z "$nested_value" ]; then
        nested_value=$(get_nested_yaml_value "registry" "image" "$config_file")
    fi
    [ -n "$nested_value" ] && IMAGE_NAME="$nested_value"

    nested_value=$(get_nested_yaml_value "registry" "registry_token" "$config_file")
    [ -n "$nested_value" ] && REGISTRY_TOKEN="$nested_value"

    nested_value=$(get_nested_yaml_value "git" "repo" "$config_file")
    if [ -z "$nested_value" ]; then
        nested_value=$(get_nested_yaml_value "git" "git_repo" "$config_file")
    fi
    [ -n "$nested_value" ] && GIT_REPO="$nested_value"

    nested_value=$(get_nested_yaml_value "git" "github_token" "$config_file")
    [ -n "$nested_value" ] && GITHUB_TOKEN="$nested_value"

    nested_value=$(get_nested_yaml_value "git" "dev_branch" "$config_file")
    [ -n "$nested_value" ] && DEV_BRANCH="$nested_value"

    nested_value=$(get_nested_yaml_value "git" "staging_branch" "$config_file")
    [ -n "$nested_value" ] && STAGING_BRANCH="$nested_value"

    nested_value=$(get_nested_yaml_value "git" "prod_branch" "$config_file")
    [ -n "$nested_value" ] && PROD_BRANCH="$nested_value"

    nested_value=$(get_nested_yaml_value "server" "name" "$config_file")
    [ -n "$nested_value" ] && SERVER_NAME="$nested_value"

    nested_value=$(get_nested_yaml_value "server" "host" "$config_file")
    [ -n "$nested_value" ] && SERVER_HOST="$nested_value"

    nested_value=$(get_nested_yaml_value "server" "port" "$config_file")
    [ -n "$nested_value" ] && SERVER_PORT="$nested_value"

    nested_value=$(get_nested_yaml_value "server" "user" "$config_file")
    [ -n "$nested_value" ] && SERVER_USER="$nested_value"

    nested_value=$(get_nested_yaml_value "server" "ssh_key" "$config_file")
    [ -n "$nested_value" ] && SERVER_SSH_KEY="$nested_value"

    nested_value=$(get_nested_yaml_value "server" "deploy_path" "$config_file")
    [ -n "$nested_value" ] && SERVER_DEPLOY_PATH="$nested_value"

    # Définir les valeurs par défaut si non spécifiées
    export PROJECT_NAME="${PROJECT_NAME:-$(basename "$CURRENT_PROJECT_DIR")}"
    export COMPOSE_PROJECT_NAME="${COMPOSE_PROJECT_NAME:-$PROJECT_NAME}"
    export LABEL_NAMESPACE="${LABEL_NAMESPACE:-cic}"
    export IMAGE_NAME="${IMAGE_NAME:-$PROJECT_NAME}"
    export DEV_PORT="${DEV_PORT:-8001}"
    export STAGING_PORT="${STAGING_PORT:-8002}"
    export PROD_PORT="${PROD_PORT:-8000}"
    export REDIS_DEV_PORT="${REDIS_DEV_PORT:-6379}"
    export REDIS_STAGING_PORT="${REDIS_STAGING_PORT:-6381}"
    export REDIS_PROD_PORT="${REDIS_PROD_PORT:-6380}"
    export DEPLOYMENT_DIR="${DEPLOYMENT_DIR:-deployment}"
    export DOCKERFILE_DIR="${DOCKERFILE_DIR:-docker}"

    # Valeurs par défaut pour le serveur distant SSH
    export SERVER_PORT="${SERVER_PORT:-22}"
    export SERVER_DEPLOY_PATH="${SERVER_DEPLOY_PATH:-/home/$SERVER_USER/apps}"

    # Valeurs par défaut pour la structure du projet
    export APP_SOURCE_DIR="${APP_SOURCE_DIR:-app}"
    export APP_DEST_DIR="${APP_DEST_DIR:-app}"
    export REQUIREMENTS_PATH="${REQUIREMENTS_PATH:-requirements.txt}"
    export APP_ENTRYPOINT="${APP_ENTRYPOINT:-app.main:app}"
    export APP_PYTHON_PATH="${APP_PYTHON_PATH:-}"
    export WORKDIR="${WORKDIR:-/app}"

    log_success "Configuration chargée: $PROJECT_NAME"
}

# Obtenir les fichiers docker-compose pour un environnement
get_compose_files() {
    local env=$1
    local config_file="$CURRENT_PROJECT_DIR/.devops.yml"

    # Chercher la config compose_files pour cet environnement
    local compose_files_line=$(grep -A 10 "^compose_files:" "$config_file" 2>/dev/null | grep "^  ${env}:" | head -1)

    if [ -n "$compose_files_line" ]; then
        # Extraire la valeur (format: "  dev: file1:file2:file3")
        local files=$(echo "$compose_files_line" | cut -d':' -f2- | xargs)
        echo "$files"
    else
        # Valeur par défaut
        echo "docker-compose.yml:docker-compose.${env}.yml"
    fi
}

# Vérifier si le projet a ses propres fichiers docker-compose
has_project_compose() {
    local deployment_dir="${DEPLOYMENT_DIR:-deployment}"
    [ -d "$CURRENT_PROJECT_DIR/$deployment_dir" ] && [ -f "$CURRENT_PROJECT_DIR/$deployment_dir/docker-compose.yml" ]
}

run_label_standardizer() {
    local mode="$1"
    shift

    local labels_script="$DEVOPS_ROOT/scripts/standardize-compose-labels.py"
    local deployment_dir="$CURRENT_PROJECT_DIR/${DEPLOYMENT_DIR:-deployment}"

    if [ ! -f "$labels_script" ]; then
        log_error "Script labels introuvable: $labels_script"
        return 1
    fi

    if ! command -v python3 >/dev/null 2>&1; then
        log_error "python3 est requis pour la commande labels"
        return 1
    fi

    python3 "$labels_script" \
        --mode "$mode" \
        --deployment-dir "$deployment_dir" \
        --project-name "${PROJECT_NAME:-${COMPOSE_PROJECT_NAME:-app}}" \
        --label-prefix "${LABEL_NAMESPACE:-cic}" \
        "$@"
}

# ============================================================================
# COMMANDES
# ============================================================================

cmd_init() {
    log_header "INITIALISATION DU PROJET"

    local project_name=$(basename "$CURRENT_PROJECT_DIR")
    local deployment_dir="$CURRENT_PROJECT_DIR/deployment"
    local docker_dir="$deployment_dir/docker"

    # =========================================================================
    # 1. Création du fichier .devops.yml
    # =========================================================================
    log_info "Création de .devops.yml..."

    cat > "$CURRENT_PROJECT_DIR/.devops.yml" <<EOF
# Configuration DevOps pour $project_name
# Ce fichier lie votre projet au système de déploiement centralisé

# Nom du projet (utilisé pour les conteneurs, réseaux, volumes)
project_name: $project_name

# Nom du projet Docker Compose (si différent du nom du projet)
compose_project_name: $project_name

# Namespace des labels de monitoring (ex: cic, orange, synelia)
label_namespace: cic

# Configuration Docker Registry
registry_username: effijeanmermoz
registry_url: docker.io
image_name: $project_name

# Configuration Git
git_repo: https://github.com/votre-org/${project_name}.git
github_token: # Optionnel: token pour repos privés

# Branches par environnement
dev_branch: dev
staging_branch: staging
prod_branch: main

# Ports (optionnel, valeurs par défaut ci-dessous)
dev_port: 8001
staging_port: 8002
prod_port: 8000
redis_dev_port: 6379
redis_staging_port: 6381
redis_prod_port: 6380

# ============================================================================
# STRUCTURE DU PROJET
# ============================================================================
# Adaptez ces chemins selon la structure de votre projet
#
# Exemples de structures courantes:
#
#   FastAPI Standard (recommandé):
#     app_source_dir: app          # dans le repo
#     app_dest_dir: app            # dans le conteneur -> /app/app/
#     requirements_path: requirements.txt
#     app_entrypoint: app.main:app # importe /app/app/main.py
#
#   FastAPI avec src/:
#     app_source_dir: app/src      # dans le repo
#     app_dest_dir: src            # dans le conteneur -> /app/src/
#     requirements_path: app/requirements.txt
#     app_entrypoint: src.main:app # importe /app/src/main.py
#
#   Django:
#     app_source_dir: src
#     app_dest_dir: src
#     requirements_path: requirements.txt
#     app_entrypoint: config.wsgi:application

# Dossier contenant le code source (relatif à la racine du projet)
app_source_dir: app

# Dossier destination dans le conteneur (relatif au WORKDIR)
# Évite les duplications de chemin comme /app/app/src/
app_dest_dir: app

# Chemin vers requirements.txt ou package.json (relatif à la racine)
requirements_path: requirements.txt

# Point d'entrée de l'application (pour uvicorn/gunicorn)
app_entrypoint: app.main:app

# PYTHONPATH additionnel (optionnel)
# Pour les imports relatifs comme "from core import ..." depuis un sous-dossier
# Exemple: /app/app/src si le code source est dans app/src/
app_python_path:

# Dossier de travail dans le conteneur
workdir: /app

# ============================================================================
# SERVEUR DISTANT - CONFIGURATION SSH
# ============================================================================

# Nom/alias du serveur
server_name: my-server

# Adresse IP ou hostname du serveur
server_host:

# Port SSH (défaut: 22)
server_port: 22

# Utilisateur SSH
server_user:

# Chemin vers la clé privée SSH
server_ssh_key: ~/.ssh/id_rsa

# Répertoire de déploiement sur le serveur distant
server_deploy_path: /home/deploy/apps
EOF

    log_success ".devops.yml créé"

    # Ajouter au .gitignore si nécessaire
    if [ -f "$CURRENT_PROJECT_DIR/.gitignore" ]; then
        if ! grep -q ".devops.yml" "$CURRENT_PROJECT_DIR/.gitignore"; then
            echo "" >> "$CURRENT_PROJECT_DIR/.gitignore"
            echo "# DevOps configuration (peut contenir des tokens)" >> "$CURRENT_PROJECT_DIR/.gitignore"
            echo ".devops.yml" >> "$CURRENT_PROJECT_DIR/.gitignore"
            log_info ".devops.yml ajouté au .gitignore"
        fi
    fi

    # Créer un template .devops.yml.example
    cat > "$CURRENT_PROJECT_DIR/.devops.yml.example" <<EOF
# Configuration DevOps pour $project_name
# Copiez ce fichier vers .devops.yml et configurez-le

project_name: $project_name
compose_project_name: $project_name
label_namespace: cic

registry_username: your-dockerhub-username
registry_url: docker.io
image_name: $project_name

git_repo: https://github.com/votre-org/${project_name}.git
github_token: # Optionnel

dev_branch: dev
staging_branch: staging
prod_branch: main

# Ports (optionnel)
dev_port: 8001
staging_port: 8002
prod_port: 8000
redis_dev_port: 6379
redis_staging_port: 6381
redis_prod_port: 6380
EOF

    log_success ".devops.yml.example créé (à versionner)"

    # =========================================================================
    # 2. Création du dossier deployment/ (copie depuis templates)
    # =========================================================================
    log_info "Création du dossier deployment/..."

    mkdir -p "$docker_dir"

    # =========================================================================
    # 2.1 Copie des Dockerfiles depuis les templates
    # =========================================================================
    log_info "Copie des Dockerfiles..."

    # Copier tous les Dockerfiles depuis $DEVOPS_ROOT/docker/
    for dockerfile in "$DEVOPS_ROOT/docker/Dockerfile."*; do
        if [ -f "$dockerfile" ]; then
            cp "$dockerfile" "$docker_dir/"
            log_info "  -> $(basename "$dockerfile")"
        fi
    done

    # Copier le .gitignore si présent
    if [ -f "$DEVOPS_ROOT/docker/.gitignore" ]; then
        cp "$DEVOPS_ROOT/docker/.gitignore" "$docker_dir/"
    fi

    log_success "Dockerfiles copiés (dev, staging, prod + versions .git)"

    # =========================================================================
    # 2.2 Copie des fichiers docker-compose depuis les templates
    # =========================================================================
    log_info "Copie des fichiers docker-compose..."

    # Copier tous les docker-compose depuis $DEVOPS_ROOT/compose/
    # et remplacer les placeholders par les valeurs du projet
    for composefile in "$DEVOPS_ROOT/compose/docker-compose"*.yml; do
        if [ -f "$composefile" ]; then
            local filename=$(basename "$composefile")
            # Copier et remplacer les placeholders
            sed -e "s/__PROJECT_NAME__/${project_name}/g" \
                "$composefile" > "$deployment_dir/$filename"
            log_info "  -> $filename"
        fi
    done

    # Remplacer __ENV__ par l'environnement approprié dans chaque fichier
    for env in dev staging prod; do
        for suffix in "" "-registry"; do
            local file="$deployment_dir/docker-compose.${env}${suffix}.yml"
            if [ -f "$file" ]; then
                sed -i '' "s/__ENV__/${env}/g" "$file"
            fi
        done
    done
    # Pour les fichiers de base (docker-compose.yml et docker-compose.registry.yml)
    # garder ${ENV} comme variable dynamique
    for file in "$deployment_dir/docker-compose.yml" "$deployment_dir/docker-compose.registry.yml"; do
        if [ -f "$file" ]; then
            sed -i '' 's/__ENV__/${ENV}/g' "$file"
        fi
    done

    log_success "docker-compose copiés et personnalisés pour $project_name"

    # Standardiser les labels <namespace>.* dès l'initialisation
    if command -v python3 >/dev/null 2>&1 && [ -f "$DEVOPS_ROOT/scripts/standardize-compose-labels.py" ]; then
        local previous_project_name="${PROJECT_NAME:-}"
        local previous_compose_project_name="${COMPOSE_PROJECT_NAME:-}"
        local previous_deployment_dir="${DEPLOYMENT_DIR:-}"
        local previous_label_namespace="${LABEL_NAMESPACE:-}"

        export PROJECT_NAME="$project_name"
        export COMPOSE_PROJECT_NAME="$project_name"
        export DEPLOYMENT_DIR="deployment"
        export LABEL_NAMESPACE="cic"

        if run_label_standardizer "sync" --no-backup >/dev/null 2>&1; then
            log_success "Labels ${LABEL_NAMESPACE}.* standardises sur les docker-compose"
        else
            log_warn "Standardisation automatique des labels impossible (a lancer plus tard avec: devops labels sync)"
        fi

        if [ -n "$previous_project_name" ]; then
            export PROJECT_NAME="$previous_project_name"
        else
            unset PROJECT_NAME
        fi
        if [ -n "$previous_compose_project_name" ]; then
            export COMPOSE_PROJECT_NAME="$previous_compose_project_name"
        else
            unset COMPOSE_PROJECT_NAME
        fi
        if [ -n "$previous_deployment_dir" ]; then
            export DEPLOYMENT_DIR="$previous_deployment_dir"
        else
            unset DEPLOYMENT_DIR
        fi
        if [ -n "$previous_label_namespace" ]; then
            export LABEL_NAMESPACE="$previous_label_namespace"
        else
            unset LABEL_NAMESPACE
        fi
    fi

    # =========================================================================
    # 2.3 Créer les fichiers .env si nécessaire
    # =========================================================================
    for env in dev staging prod; do
        if [ ! -f "$CURRENT_PROJECT_DIR/.env.$env" ] && [ -f "$CURRENT_PROJECT_DIR/.env.example" ]; then
            cp "$CURRENT_PROJECT_DIR/.env.example" "$CURRENT_PROJECT_DIR/.env.$env"
            log_info ".env.$env créé depuis .env.example"
        fi
    done

    # =========================================================================
    # Résumé
    # =========================================================================
    echo ""
    log_success "Projet initialisé avec succès !"
    echo ""
    echo -e "${WHITE}Structure créée:${NC}"
    echo "  ├── .devops.yml              (configuration)"
    echo "  ├── .devops.yml.example      (template à versionner)"
    echo "  └── deployment/"
    echo "      ├── docker/"
    echo "      │   ├── Dockerfile.dev          (build local)"
    echo "      │   ├── Dockerfile.staging"
    echo "      │   ├── Dockerfile.prod"
    echo "      │   ├── Dockerfile.dev.git      (clone depuis Git)"
    echo "      │   ├── Dockerfile.staging.git"
    echo "      │   └── Dockerfile.prod.git"
    echo "      ├── docker-compose.yml         (base - build local)"
    echo "      ├── docker-compose.dev.yml"
    echo "      ├── docker-compose.staging.yml"
    echo "      ├── docker-compose.prod.yml"
    echo "      ├── docker-compose.registry.yml     (base - registry)"
    echo "      ├── docker-compose.dev-registry.yml"
    echo "      ├── docker-compose.staging-registry.yml"
    echo "      └── docker-compose.prod-registry.yml"
    echo ""
    log_info "Prochaines étapes:"
    echo "  1. Éditez .devops.yml avec votre configuration"
    echo "  2. Adaptez les Dockerfiles si besoin (Node.js, Go, etc.)"
    echo "  3. Configurez vos .env.dev, .env.staging, .env.prod"
    echo "  4. Déployez: devops deploy dev"
}

cmd_deploy() {
    load_project_config

    local env=$1
    shift

    log_header "DÉPLOIEMENT - $PROJECT_NAME ($env)"

    # Vérifier que le dossier deployment existe dans le projet
    local project_deployment="$CURRENT_PROJECT_DIR/$DEPLOYMENT_DIR"
    if [ ! -d "$project_deployment" ]; then
        log_error "Dossier $DEPLOYMENT_DIR introuvable dans le projet"
        log_info "Structure attendue: $project_deployment"
        exit 1
    fi

    # Définir PROJECT_ROOT pour les scripts
    export PROJECT_ROOT="$CURRENT_PROJECT_DIR"
    export ENV="$env"

    # Les scripts deployment/scripts/deploy.sh utilisent ces variables
    # Elles ont déjà été exportées par load_project_config()

    # Appeler le script de déploiement centralisé
    local deploy_script="$DEVOPS_ROOT/scripts/deploy.sh"

    if [ ! -f "$deploy_script" ]; then
        log_error "Script de déploiement introuvable: $deploy_script"
        exit 1
    fi

    log_info "Appel du script: $deploy_script"
    bash "$deploy_script" deploy "$env" "$@"

    log_success "Déploiement terminé !"
}

cmd_package() {
    load_project_config

    log_header "CRÉATION DU PACKAGE - $PROJECT_NAME"

    # Définir PROJECT_ROOT pour les scripts
    export PROJECT_ROOT="$CURRENT_PROJECT_DIR"

    # Appeler le script de création de package centralisé
    local package_script="$DEVOPS_ROOT/scripts/create-deployment-package.sh"

    if [ ! -f "$package_script" ]; then
        log_error "Script de package introuvable: $package_script"
        exit 1
    fi

    log_info "Appel du script: $package_script"
    bash "$package_script" "$@"

    log_success "Package créé !"
}

cmd_registry() {
    load_project_config

    local action=$1
    shift

    log_header "REGISTRY - $PROJECT_NAME"

    # Définir PROJECT_ROOT pour les scripts
    export PROJECT_ROOT="$CURRENT_PROJECT_DIR"

    # Appeler le script registry centralisé
    local registry_script="$DEVOPS_ROOT/scripts/registry.sh"

    if [ ! -f "$registry_script" ]; then
        log_error "Script registry introuvable: $registry_script"
        exit 1
    fi

    log_info "Appel du script: $registry_script"
    bash "$registry_script" "$action" "$@"
}

cmd_audit() {
    load_project_config
    export PROJECT_ROOT="$CURRENT_PROJECT_DIR"

    local audit_script="$DEVOPS_ROOT/scripts/audit-security.sh"
    if [ ! -f "$audit_script" ]; then
        log_error "Script audit-security.sh introuvable"
        exit 1
    fi

    log_info "Appel du script: $audit_script"
    bash "$audit_script" "$@"
}

cmd_encrypt() {
    load_project_config
    export PROJECT_ROOT="$CURRENT_PROJECT_DIR"

    local encrypt_script="$DEVOPS_ROOT/scripts/auto-encrypt-envs.sh"
    if [ ! -f "$encrypt_script" ]; then
        log_error "Script auto-encrypt-envs.sh introuvable"
        exit 1
    fi

    log_info "Appel du script: $encrypt_script"
    (
        cd "$CURRENT_PROJECT_DIR"
        bash "$encrypt_script" "$@"
    )
}

cmd_deploy_registry() {
    load_project_config
    export PROJECT_ROOT="$CURRENT_PROJECT_DIR"

    local deploy_registry_script="$DEVOPS_ROOT/scripts/deploy-registry.sh"
    if [ ! -f "$deploy_registry_script" ]; then
        log_error "Script deploy-registry.sh introuvable"
        exit 1
    fi

    log_info "Appel du script: $deploy_registry_script"
    bash "$deploy_registry_script" "$@"
}

cmd_labels() {
    load_project_config
    export PROJECT_ROOT="$CURRENT_PROJECT_DIR"

    local action="${1:-sync}"
    if [[ "$action" == --* ]]; then
        action="sync"
    else
        shift || true
    fi

    log_header "LABELS - $PROJECT_NAME"

    case "$action" in
        sync)
            run_label_standardizer "sync" "$@"
            ;;
        check)
            run_label_standardizer "check" "$@"
            ;;
        *)
            log_error "Action labels inconnue: $action"
            echo "Usage: devops labels [sync|check] [--label-prefix namespace] [--dry-run] [--no-backup]"
            return 1
            ;;
    esac
}

cmd_interactive() {
    load_project_config
    export PROJECT_ROOT="$CURRENT_PROJECT_DIR"
    export ENV="${ENV:-dev}"

    while true; do
        clear
        echo -e "${CYAN}╔════════════════════════════════════════════════════════╗${NC}"
        echo -e "${CYAN}║${NC}  ${WHITE}DevOps CLI - ${PROJECT_NAME}${NC}"
        echo -e "${CYAN}╚════════════════════════════════════════════════════════╝${NC}"
        echo ""
        echo -e "${WHITE}Commandes disponibles:${NC}"
        echo ""
        echo -e "  ${CYAN}1)${NC} ${GREEN}deploy${NC}         - Déployer le projet (build local)"
        echo -e "  ${CYAN}2)${NC} ${GREEN}package${NC}        - Créer un package de déploiement"
        echo -e "  ${CYAN}3)${NC} ${GREEN}registry${NC}       - Gérer le Docker Registry"
        echo -e "  ${CYAN}4)${NC} ${GREEN}deploy-registry${NC} - Déployer depuis Docker Hub"
        echo -e "  ${CYAN}5)${NC} ${GREEN}audit${NC}          - Audit de sécurité"
        echo -e "  ${CYAN}6)${NC} ${GREEN}encrypt${NC}        - Chiffrer les fichiers .env (option: --keep-clear)"
        echo -e "  ${CYAN}7)${NC} ${GREEN}labels${NC}         - Standardiser les labels <namespace>.*"
        echo ""
        echo -e "  ${CYAN}h)${NC} ${GREEN}help${NC}           - Afficher l'aide complète"
        echo -e "  ${CYAN}0)${NC} ${RED}Quitter${NC}"
        echo ""
        echo -e "${CYAN}────────────────────────────────────────────────────────${NC}"
        echo ""
        read -p "Votre choix: " choice

        case $choice in
            1)
                # Lancer deploy.sh en mode interactif
                local deploy_script="$DEVOPS_ROOT/scripts/deploy.sh"
                if [ -f "$deploy_script" ]; then
                    bash "$deploy_script"
                else
                    log_error "Script deploy.sh introuvable"
                fi
                echo ""
                read -p "Appuyez sur Entrée pour continuer..."
                ;;
            2)
                # Lancer create-deployment-package.sh en mode interactif (affiche son propre menu)
                local package_script="$DEVOPS_ROOT/scripts/create-deployment-package.sh"
                if [ -f "$package_script" ]; then
                    bash "$package_script"
                else
                    log_error "Script create-deployment-package.sh introuvable"
                fi
                ;;
            3)
                # Lancer registry.sh en mode interactif (affiche son propre menu)
                local registry_script="$DEVOPS_ROOT/scripts/registry.sh"
                if [ -f "$registry_script" ]; then
                    bash "$registry_script"
                else
                    log_error "Script registry.sh introuvable"
                fi
                ;;
            4)
                # Lancer deploy-registry.sh en mode interactif
                local deploy_registry_script="$DEVOPS_ROOT/scripts/deploy-registry.sh"
                if [ -f "$deploy_registry_script" ]; then
                    bash "$deploy_registry_script"
                else
                    log_error "Script deploy-registry.sh introuvable"
                fi
                ;;
            5)
                cmd_audit
                echo ""
                read -p "Appuyez sur Entrée pour continuer..."
                ;;
            6)
                cmd_encrypt
                echo ""
                read -p "Appuyez sur Entrée pour continuer..."
                ;;
            7)
                read -p "Action labels (sync/check) [sync]: " labels_action
                labels_action="${labels_action:-sync}"
                cmd_labels "$labels_action"
                echo ""
                read -p "Appuyez sur Entrée pour continuer..."
                ;;
            h|H)
                cmd_help
                echo ""
                read -p "Appuyez sur Entrée pour continuer..."
                ;;
            0|q|Q)
                echo ""
                log_info "Au revoir !"
                exit 0
                ;;
            *)
                log_error "Option invalide"
                sleep 1
                ;;
        esac
    done
}

