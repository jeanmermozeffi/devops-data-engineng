    echo -e "    ${GREEN}labels [sync|check]${NC}     Standardiser/verifier les labels <namespace>.*"
    echo -e "    ${GREEN}help${NC}                    Afficher cette aide"
    echo ""
    echo -e "${WHITE}EXEMPLES:${NC}"
