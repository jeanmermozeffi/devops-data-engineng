# ============================================================================
# Configuration pour la création du package de déploiement
# ============================================================================
# Ce fichier est un TEMPLATE. Copiez-le vers .env.deployment et modifiez
# les valeurs selon votre environnement.
#
# cp deployment/.env.deployment.example deployment/.env.deployment
# ============================================================================

# -----------------------------------------------------------------------------
# Configuration du package
# -----------------------------------------------------------------------------
# Chemin de destination du package sur la machine locale
PACKAGE_DIR=~/cicbi-deployment-package

# -----------------------------------------------------------------------------
# Configuration Docker Registry
# -----------------------------------------------------------------------------
# Type de registry (dockerhub, ghcr, custom)
REGISTRY_TYPE=dockerhub

# URL du registry
REGISTRY_URL=docker.io

# Nom d'utilisateur du registry
REGISTRY_USERNAME=votre-username

# Nom de l'image Docker
IMAGE_NAME=cicbi-api-backend

# -----------------------------------------------------------------------------
# Configuration SSH (serveur de destination)
# -----------------------------------------------------------------------------
# Adresse IP ou hostname du serveur (laissez vide si pas de transfert auto)
SSH_HOST=

# Nom d'utilisateur SSH
SSH_USER=cicbi

# Port SSH
SSH_PORT=22

# Chemin de destination sur le serveur
SSH_PATH=/srv/home/cicbi-api-backend

# Méthode d'authentification (true = mot de passe, false = clé SSH)
SSH_USE_PASSWORD=false

# Fichier de clé SSH à utiliser (laissez vide pour utiliser la clé par défaut)
# Exemple: ~/.ssh/id_rsa_cicbi_pro_lnx
SSH_IDENTITY_FILE=

# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------
# - Remplissez SSH_HOST pour activer le transfert automatique
# - Les valeurs peuvent être surchargées via le menu interactif du script
# - Ne commitez pas le fichier .env.deployment avec des données sensibles
