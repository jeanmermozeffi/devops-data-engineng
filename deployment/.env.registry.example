# ============================================================================
# Configuration Registry - Fichier d'exemple
# Copier ce fichier en .env.registry et ajuster les valeurs
# ============================================================================
#
# COMMANDES:
#   cp .env.registry.example .env.registry
#   nano .env.registry  # Éditer les valeurs
#
# ============================================================================

# ============================================================================
# CONFIGURATION DU REGISTRY
# ============================================================================

# Type de registry (dockerhub, gitlab, github, custom)
REGISTRY_TYPE=dockerhub

# URL du registry
# - Docker Hub: docker.io
# - GitHub: ghcr.io
# - GitLab: registry.gitlab.com
# - Custom: registry.mondomaine.com
REGISTRY_URL=docker.io

# Nom d'utilisateur du registry
REGISTRY_USERNAME=effijeanmermoz

# Nom de l'image
IMAGE_NAME=cicbi-api-backend

# ============================================================================
# CONFIGURATION DE L'ENVIRONNEMENT
# ============================================================================

# Environnement (dev ou prod)
ENVIRONMENT=dev

# Tag de l'image à déployer
# Options:
#   - dev-latest          : Dernière version dev
#   - prod-latest         : Dernière version prod
#   - dev-v20251216-...   : Version spécifique dev
#   - prod-v1.2.3         : Version spécifique prod avec tag manuel
IMAGE_TAG=dev-latest

# ============================================================================
# IMAGE COMPLÈTE (Construite automatiquement)
# Format: ${REGISTRY_URL}/${REGISTRY_USERNAME}/${IMAGE_NAME}:${IMAGE_TAG}
# Exemples:
#   - docker.io/effijeanmermoz/cicbi-api-backend:dev-latest
#   - ghcr.io/cicbi/cicbi-api-backend:prod-v1.2.3
# ============================================================================

# Cette variable sera construite automatiquement par le script de déploiement
# Vous pouvez la surcharger manuellement si nécessaire
# IMAGE_FULL=${REGISTRY_URL}/${REGISTRY_USERNAME}/${IMAGE_NAME}:${IMAGE_TAG}

# ============================================================================
# NOTES
# ============================================================================
#
# 1. Pour déployer en dev avec le tag latest:
#    ENVIRONMENT=dev
#    IMAGE_TAG=dev-latest
#
# 2. Pour déployer en prod avec une version spécifique:
#    ENVIRONMENT=prod
#    IMAGE_TAG=prod-v1.2.3
#
# 3. Le script deploy-registry.sh peut lister les tags disponibles:
#    ./scripts/deploy-registry.sh list-tags dev
#    ./scripts/deploy-registry.sh list-tags prod
#
# ============================================================================

