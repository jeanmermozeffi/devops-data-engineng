# ============================================================================
# Configuration du Registry Docker
# ============================================================================
#
# Copiez ce fichier vers .env.registry et configurez vos valeurs
# cp .env.registry.example .env.registry
#
# IMPORTANT: Ajoutez .env.registry à .gitignore pour ne pas exposer vos secrets
#

# ────────────────────────────────────────────────────────────────────────────
# Registry Docker
# ────────────────────────────────────────────────────────────────────────────

# URL du registry Docker
# - Docker Hub: docker.io (par défaut)
# - GitHub Container Registry: ghcr.io
# - GitLab Container Registry: registry.gitlab.com
# - AWS ECR: <account-id>.dkr.ecr.<region>.amazonaws.com
# - Azure ACR: <registry-name>.azurecr.io
# - Google GCR: gcr.io/<project-id>
REGISTRY_URL=docker.io

# Nom d'utilisateur du registry
REGISTRY_USERNAME=cicbi

# Mot de passe ou token du registry
# Pour Docker Hub: Utilisez un Access Token (https://hub.docker.com/settings/security)
# Pour GitHub: Utilisez un Personal Access Token avec scope 'write:packages'
# Pour GitLab: Utilisez un Deploy Token ou Personal Access Token
REGISTRY_PASSWORD=

# Ou utilisez un token (priorité sur REGISTRY_PASSWORD si défini)
REGISTRY_TOKEN=

# Nom de l'image (sans le username/registry)
IMAGE_NAME=cicbi-api


# ────────────────────────────────────────────────────────────────────────────
# Configuration Git
# ────────────────────────────────────────────────────────────────────────────

# URL du repository Git (HTTPS)
GIT_REPO=https://github.com/cicbi/cicbi-api-backend.git

# Token GitHub pour les repos privés (optionnel pour repos publics)
# Créer un token: https://github.com/settings/tokens
# Permissions requises: repo (Full control of private repositories)
GITHUB_TOKEN=

# Branches Git par environnement
DEV_BRANCH=develop
PROD_BRANCH=main


# ────────────────────────────────────────────────────────────────────────────
# Exemples de configuration par registry
# ────────────────────────────────────────────────────────────────────────────

# ─── Docker Hub ───
# REGISTRY_URL=docker.io
# REGISTRY_USERNAME=votre-username
# REGISTRY_TOKEN=dckr_pat_xxxxxxxxxxxxxxxxxxxxx
# IMAGE_NAME=cicbi-api
# Résultat: docker.io/votre-username/cicbi-api:dev-latest

# ─── GitHub Container Registry (ghcr.io) ───
# REGISTRY_URL=ghcr.io
# REGISTRY_USERNAME=cicbi  # ou votre organisation
# REGISTRY_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# IMAGE_NAME=cicbi-api
# Résultat: ghcr.io/cicbi/cicbi-api:dev-latest

# ─── GitLab Container Registry ───
# REGISTRY_URL=registry.gitlab.com
# REGISTRY_USERNAME=votre-username  # ou nom du projet
# REGISTRY_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
# IMAGE_NAME=cicbi-api
# Résultat: registry.gitlab.com/votre-username/cicbi-api:dev-latest

# ─── AWS ECR ───
# REGISTRY_URL=123456789012.dkr.ecr.us-east-1.amazonaws.com
# REGISTRY_USERNAME=AWS
# REGISTRY_PASSWORD=$(aws ecr get-login-password --region us-east-1)
# IMAGE_NAME=cicbi-api
# Résultat: 123456789012.dkr.ecr.us-east-1.amazonaws.com/AWS/cicbi-api:dev-latest

# ─── Azure Container Registry ───
# REGISTRY_URL=myregistry.azurecr.io
# REGISTRY_USERNAME=myregistry
# REGISTRY_PASSWORD=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# IMAGE_NAME=cicbi-api
# Résultat: myregistry.azurecr.io/myregistry/cicbi-api:dev-latest

# ─── Google Container Registry ───
# REGISTRY_URL=gcr.io/my-project-id
# REGISTRY_USERNAME=_json_key
# REGISTRY_PASSWORD=$(cat key.json)
# IMAGE_NAME=cicbi-api
# Résultat: gcr.io/my-project-id/_json_key/cicbi-api:dev-latest


# ────────────────────────────────────────────────────────────────────────────
# Notes
# ────────────────────────────────────────────────────────────────────────────
#
# 1. Pour Docker Hub, créez un Access Token:
#    - Allez sur https://hub.docker.com/settings/security
#    - Créez un nouveau Access Token avec les permissions Read & Write
#    - Utilisez ce token comme REGISTRY_TOKEN
#
# 2. Pour GitHub Container Registry:
#    - Créez un Personal Access Token avec le scope 'write:packages'
#    - https://github.com/settings/tokens
#
# 3. Pour les repos Git privés:
#    - Créez un GitHub Token avec le scope 'repo'
#    - Ajoutez-le dans GITHUB_TOKEN
#
# 4. Sécurité:
#    - Ne commitez JAMAIS ce fichier avec vos secrets
#    - Ajoutez .env.registry à .gitignore
#    - Utilisez des variables d'environnement en CI/CD
#
