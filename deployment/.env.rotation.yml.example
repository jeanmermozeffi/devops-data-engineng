# Rotation des secrets .env (optionnel)
#
# Copiez ce fichier à la racine du projet à déployer:
#   cp deployment/.env.rotation.yml.example .env.rotation.yml
#
# Ce fichier est lu par deployment/scripts/rotate-env-secrets.py

# Longueur des secrets générés (défaut: 16)
length: 16

# Variables à régénérer dans .env.<env>
variables:
  - POSTGRES_PASSWORD
  - AIRFLOW_DB_PASSWORD

# Optionnel: surcharge par environnement
secret_rotation:
  variables_by_env:
    dev:
      - POSTGRES_PASSWORD
    staging:
      - POSTGRES_PASSWORD
      - AIRFLOW_DB_PASSWORD
    prod:
      - POSTGRES_PASSWORD
      - AIRFLOW_DB_PASSWORD
