# Host identity (must be unique in central dashboards)
AGENT_HOST=project-prod-01
AGENT_ENV=prod
AGENT_REGION=ca-central-1

# Fallback project label when cic.project absent on containers
AGENT_PROJECT_DEFAULT=unknown-project

# Loki central endpoint
LOKI_PUSH_URL=http://monitoring-central.example.com:3100/loki/api/v1/push

# Docker network of app stack
APP_DOCKER_NETWORK=my-project-prod-network

# Exposed exporter ports on agent host
NODE_EXPORTER_PORT=9100
CADVISOR_PORT=8080

# Optional: PostgreSQL exporter (profile 'postgres')
POSTGRES_EXPORTER_PORT=9187
POSTGRES_EXPORTER_DSN=postgresql://app:change-me@postgres:5432/app?sslmode=disable

# Optional: Airflow exporter from Airflow metadata DB (profile 'airflow')
AIRFLOW_EXPORTER_PORT=9188
AIRFLOW_EXPORTER_DSN=postgresql://airflow:change-me@postgres:5432/airflow?sslmode=disable

# Optional: Redis exporter (profile 'redis')
REDIS_EXPORTER_PORT=9121
REDIS_EXPORTER_ADDR=redis://redis:6379
REDIS_EXPORTER_PASSWORD=
