##############################
# Dockerfile DEV - Clone depuis Git
# Build: docker build --build-arg GIT_REPO=https://github.com/org/repo.git --build-arg GIT_BRANCH=develop --secret id=github_token,src=$HOME/.github_token -f deployment/docker/Dockerfile.dev.git -t project-name:dev .
# Note: GIT_REPO doit être passé en argument lors du build
##############################

##############################
# 1. Phase « git-cloner »
# Clone le code depuis Git EN PREMIER
##############################

FROM python:3.11-slim AS git-cloner

# Arguments de build pour le repo Git (GIT_REPO doit être passé lors du build)
ARG GIT_BRANCH=develop
ARG GIT_REPO

# Installer Git
RUN apt-get update && apt-get install -y git \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /tmp

# Cloner le repo avec authentification si token fourni via secret
# Note: Le token est utilisé comme secret Docker et n'est jamais persisté dans l'image
RUN --mount=type=secret,id=github_token \
    --mount=type=secret,id=git_username \
    if [ -f /run/secrets/github_token ]; then \
        echo "=== DEBUG: Clonage avec authentification ==="; \
        GIT_TOKEN=$(cat /run/secrets/github_token | tr -d '\n\r\t ') && \
        echo "DEBUG: Token chargé"; \
        echo "DEBUG: Token commence par: $(echo "$GIT_TOKEN" | cut -c1-10)..."; \
        REPO_PATH=$(echo ${GIT_REPO} | sed 's|https://||') && \
        echo "DEBUG: REPO_PATH=${REPO_PATH}"; \
        if echo "${GIT_REPO}" | grep -q "gitlab.com"; then \
            echo "DEBUG: GitLab détecté"; \
            if [ -f /run/secrets/git_username ]; then \
                GIT_USER=$(cat /run/secrets/git_username | tr -d '\n\r\t '); \
                echo "DEBUG: Username GitLab: ${GIT_USER}"; \
                REPO_URL="https://${GIT_USER}:${GIT_TOKEN}@${REPO_PATH}"; \
                echo "DEBUG: URL construite: https://${GIT_USER}:***@${REPO_PATH}"; \
            else \
                echo "DEBUG: Pas de username, utilisation oauth2"; \
                REPO_URL="https://oauth2:${GIT_TOKEN}@${REPO_PATH}"; \
            fi; \
        else \
            echo "DEBUG: GitHub détecté"; \
            REPO_URL="https://oauth2:${GIT_TOKEN}@${REPO_PATH}"; \
        fi && \
        echo "DEBUG: Lancement du clone..." && \
        git clone --branch ${GIT_BRANCH} --depth 1 "${REPO_URL}" app && \
        echo "DEBUG: Clone réussi!" && \
        unset GIT_TOKEN GIT_USER REPO_URL REPO_PATH; \
    else \
        echo "Clonage sans authentification depuis ${GIT_REPO}..."; \
        git clone --branch ${GIT_BRANCH} --depth 1 ${GIT_REPO} app; \
    fi

# Afficher les infos de la branche clonée
RUN cd app && \
    echo "=== Info Git ===" && \
    git log -1 --pretty=format:"Commit: %H%nAuthor: %an%nDate: %ad%nMessage: %s%n" && \
    echo "Branch: ${GIT_BRANCH}"


##############################
# 2. Phase « builder »
# Installer les dépendances Python
##############################

FROM python:3.11-slim AS builder
LABEL authors="effijeanmermoz"
LABEL environment="dev"

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# Installer les dépendances système pour psycopg2
RUN apt-get update && apt-get install -y \
    gcc \
    libpq-dev \
    libc-dev \
    libssl-dev \
    make \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Copier requirements.txt depuis git-cloner
COPY --from=git-cloner /tmp/app/app/requirements.txt .
RUN pip install --upgrade pip \
    && pip install --no-cache-dir -r requirements.txt


##############################
# 3. Phase « runtime »
##############################

FROM python:3.11-slim
LABEL authors="effijeanmermoz"
LABEL environment="dev"

ARG GIT_BRANCH=develop
ENV APP_ENV=dev \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    GIT_BRANCH=${GIT_BRANCH}

WORKDIR /app/src

# Installer curl pour le healthcheck
RUN apt-get update && apt-get install -y curl \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Récupérer les paquets Python depuis le builder
COPY --from=builder /usr/local/lib/python3.11/site-packages /usr/local/lib/python3.11/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

# Copier le code source depuis git-cloner
COPY --from=git-cloner /tmp/app/app/src /app/src

# Exposer le port 80 (Uvicorn tournera sur 80)
EXPOSE 80

HEALTHCHECK --interval=30s --timeout=3s \
    CMD curl -f http://localhost:80/health || exit 1

# Dev : avec --reload pour le hot-reload
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "80", "--reload"]
